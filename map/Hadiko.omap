              <point_symbol rotatable="true" inner_radius="300" inner_color="4" outer_width="0" outer_color="-1" elements="0" />
            </symbol>
          </mid_symbol>
        </line_symbol>
      </symbol>
      <symbol type="2" id="131" code="513.2" name="Passable retained wall">
        <description>A passable wall which is seen only from one side. Half dot must point to the lower level.
Height is 0.6 - 1.5 m. If lower, use symbol Step or edge of paved area (501.1).
Minimum length (isolated): 2.4 mm (footprint 9.6 m).</description>
