      <symbol type="1" id="162" code="701" name="Start">
        <description>The start or map issue point (if not at the start) is shown by an equilateral triangle which points in the direction of the first control.
The centre of the triangle shows the precise position of the start point.</description>
        <point_symbol rotatable="true" inner_radius="1000" inner_color="-1" outer_width="0" outer_color="-1" elements="1">
          <element>
