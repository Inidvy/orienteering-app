              <pattern rotation="0">
                <coord x="0" y="0" />
              </pattern>
            </object>
          </element>
        </point_symbol>
      </symbol>
      <symbol type="1" id="163" code="702" name=" Map issue point">
        <description>If there is a marked route to the start point, the map issue point is marked using this symbol.</description>
        <point_symbol rotatable="true" inner_radius="1000" inner_color="-1" outer_width="0" outer_color="-1" elements="1">
          <element>
            <symbol type="2" code="">
              <line_symbol color="0" line_width="600" minimum_length="0" join_style="1" cap_style="0" start_offset="0" end_offset="0" segment_length="4000" end_length="0" show_at_least_one_symbol="true" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" dash_length="4000" break_length="1000" dashes_in_group="1" in_group_break_length="500" mid_symbols_per_spot="1" mid_symbol_distance="0" />
