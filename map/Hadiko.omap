          </start_symbol>
          <mid_symbol>
            <symbol type="1" code="" name="Mid symbol">
              <point_symbol rotatable="true" inner_radius="1000" inner_color="-1" outer_width="0" outer_color="-1" elements="0" />
            </symbol>
          </mid_symbol>
          <end_symbol>
